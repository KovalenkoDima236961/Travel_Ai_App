# Root build contexts are used by worker-service and the one-shot migration
# runner. Keep only their Go sources, migration assets, and runner script.
*

!services/auth-service
!services/user-service
!services/trip-service
!services/notification-service
!services/external-integrations-service
!services/worker-service
!infra
!scripts/run-migrations.sh

# Never send local state, credentials, or generated artifacts to Docker.
**/.git
**/.env
**/.env.*
**/.cache
**/bin
**/tmp
**/coverage.out
**/data/receipts
**/data/exports
backups
exports
receipts
graphify-out
