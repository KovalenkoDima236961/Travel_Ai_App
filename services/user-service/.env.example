# User Service environment example.
# Copy to .env for local shell usage, then load it with:
#   set -a; source .env; set +a

APP_ENV=local

HTTP_ADDRESS=:8083
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

AUTH_REQUIRED=true
JWT_ACCESS_SECRET=change-me-in-development
AUTH_HEADER_NAME=Authorization
DEV_USER_ID=00000000-0000-0000-0000-000000000001

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,PUT,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# For local development with a host Postgres container, use localhost.
# In Docker Compose, use POSTGRES_HOST=postgres.
POSTGRES_DB=user_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONNS=10
POSTGRES_MIG_PATH=./migrations
