# User Service environment example.
# Copy to .env for local shell usage, then load it with:
#   set -a; source .env; set +a

APP_ENV=local

HTTP_ADDRESS=:8083
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

AUTH_REQUIRED=true
JWT_ACCESS_SECRET=change-me-in-development
AUTH_HEADER_NAME=Authorization
DEV_USER_ID=00000000-0000-0000-0000-000000000001

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Private, authenticated account-export packages. These settings only govern
# generated files; they never enable automatic account or source-data deletion.
DATA_EXPORT_ENABLED=true
DATA_EXPORT_STORAGE_DIR=./data/exports
DATA_EXPORT_TTL_HOURS=24
DATA_EXPORT_MAX_ACCOUNT_EXPORT_MB=250
DATA_EXPORT_CLEANUP_ENABLED=true
DATA_EXPORT_CLEANUP_INTERVAL_MINUTES=60
ACCOUNT_EXPORT_TRIP_DATA_ENABLED=true
TRIP_SERVICE_URL=http://localhost:8080
TRIP_SERVICE_TOKEN=dev-internal-service-token
TRIP_EXPORT_TIMEOUT_SECONDS=60

# For local development with a host Postgres container, use localhost.
# In Docker Compose, use POSTGRES_HOST=postgres.
POSTGRES_DB=user_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONNS=10
POSTGRES_MIG_PATH=./migrations
