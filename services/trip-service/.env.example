# Trip Service environment example.
# Copy to .env for local shell usage, then load it with:
#   set -a; source .env; set +a

APP_ENV=development

HTTP_ADDRESS=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=150s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

AUTH_REQUIRED=true
JWT_ACCESS_SECRET=change-me-in-development
AUTH_HEADER_NAME=Authorization
DEV_USER_ID=00000000-0000-0000-0000-000000000001

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# For local development with a host Postgres container, use localhost.
# In Docker Compose, use POSTGRES_HOST=postgres.
POSTGRES_DB=trip_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONNS=10
POSTGRES_MIG_PATH=./migrations

# Supported values: mock, http.
# mock generates deterministic local itineraries.
# http calls AI Planning Service.
ITINERARY_GENERATOR_MODE=mock

# Used only when ITINERARY_GENERATOR_MODE=http.
# For local AI Planning Service, use http://localhost:8000.
# In Docker Compose, use http://ai-planning-service:8000.
AI_PLANNING_SERVICE_URL=http://localhost:8000
AI_PLANNING_TIMEOUT_SECONDS=120
USER_SERVICE_URL=http://localhost:8083
USER_CONTEXT_ENABLED=true
USER_CONTEXT_TIMEOUT_SECONDS=5
USER_CONTEXT_FAIL_OPEN=true
EXTERNAL_INTEGRATIONS_SERVICE_URL=http://localhost:8084
WEATHER_CONTEXT_ENABLED=true
WEATHER_CONTEXT_TIMEOUT_SECONDS=5
WEATHER_CONTEXT_FAIL_OPEN=true
PLACE_ENRICHMENT_ENABLED=true
PLACE_ENRICHMENT_FAIL_OPEN=true
PLACE_ENRICHMENT_TIMEOUT_SECONDS=5
PLACE_ENRICHMENT_MIN_CONFIDENCE=0.75
PLACE_ENRICHMENT_MAX_ITEMS=20
PLACE_ENRICHMENT_OVERWRITE_EXISTING=false
