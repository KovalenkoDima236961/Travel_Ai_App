# Trip Service environment example.
# Copy to .env for local shell usage, then load it with:
#   set -a; source .env; set +a

APP_ENV=development

HTTP_ADDRESS=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=150s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

# For local development with a host Postgres container, use localhost.
# In Docker Compose, use POSTGRES_HOST=postgres.
POSTGRES_DB=trip_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONNS=10
POSTGRES_MIG_PATH=./migrations

# Supported values: mock, http.
# mock generates deterministic local itineraries.
# http calls AI Planning Service.
ITINERARY_GENERATOR_MODE=mock

# Used only when ITINERARY_GENERATOR_MODE=http.
# For local AI Planning Service, use http://localhost:8000.
# In Docker Compose, use http://ai-planning-service:8000.
AI_PLANNING_SERVICE_URL=http://localhost:8000
AI_PLANNING_TIMEOUT_SECONDS=120
