# External Integrations Service environment example.
# Copy to .env for local shell usage, then load it with:
#   set -a; source .env; set +a

APP_ENV=development

HTTP_ADDR=:8084
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

PLACE_PROVIDER=mock
GOOGLE_PLACES_API_KEY=
MAPBOX_API_KEY=

# Routing provider. mock (default) | ors (OpenRouteService).
# The real ORS provider is opt-in; the mock provider stays the default and the
# fail-open fallback. Never commit a real ORS_API_KEY.
ROUTE_PROVIDER=mock
ROUTE_PROVIDER_FALLBACK_TO_MOCK=true
ROUTE_PROVIDER_TIMEOUT_SECONDS=8
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
ORS_PROFILE_WALKING=foot-walking
ORS_PROFILE_DRIVING=driving-car
ORS_PROFILE_CYCLING=cycling-regular
ROUTE_CACHE_ENABLED=true
ROUTE_CACHE_TTL_SECONDS=21600

# Weather provider. mock (default) | openweathermap (OpenWeatherMap).
# The real provider is opt-in; mock stays the default and fallback.
# Never commit a real OPENWEATHER_API_KEY.
WEATHER_PROVIDER=mock
WEATHER_PROVIDER_FALLBACK_TO_MOCK=true
WEATHER_PROVIDER_TIMEOUT_SECONDS=8
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
OPENWEATHER_UNITS=metric
WEATHER_CACHE_ENABLED=true
WEATHER_CACHE_TTL_SECONDS=3600

# Documented for future real providers; unused in v1.
OSRM_BASE_URL=
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=
OPEN_METEO_BASE_URL=
WEATHER_API_KEY=
