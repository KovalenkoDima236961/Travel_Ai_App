# External Integrations Service environment example.
# Copy to .env for local shell usage, then load it with:
#   set -a; source .env; set +a

APP_ENV=local

HTTP_ADDR=:8084
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

JWT_ACCESS_SECRET=change-me-in-development
AUTH_HEADER_NAME=Authorization
INTERNAL_SERVICE_TOKEN=dev-internal-service-token

OPS_DASHBOARD_ENABLED=false
OPS_ADMIN_EMAILS=
OPS_INTERNAL_SERVICE_TOKEN=dev-internal-service-token

CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

PLACE_PROVIDER=mock
GOOGLE_PLACES_API_KEY=
MAPBOX_API_KEY=

# Routing provider. mock (default) | ors (OpenRouteService).
# The real ORS provider is opt-in; the mock provider stays the default and the
# fail-open fallback. Never commit a real ORS_API_KEY.
ROUTE_PROVIDER=mock
ROUTE_PROVIDER_FALLBACK_TO_MOCK=true
ROUTE_PROVIDER_TIMEOUT_SECONDS=8
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
ORS_PROFILE_WALKING=foot-walking
ORS_PROFILE_DRIVING=driving-car
ORS_PROFILE_CYCLING=cycling-regular
ROUTE_CACHE_ENABLED=true
ROUTE_CACHE_TTL_SECONDS=21600

# Weather provider. mock (default) | openweathermap (OpenWeatherMap).
# The real provider is opt-in; mock stays the default and fallback.
# Never commit a real OPENWEATHER_API_KEY.
WEATHER_PROVIDER=mock
WEATHER_PROVIDER_FALLBACK_TO_MOCK=true
WEATHER_PROVIDER_TIMEOUT_SECONDS=8
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
OPENWEATHER_UNITS=metric
WEATHER_CACHE_ENABLED=true
WEATHER_CACHE_TTL_SECONDS=3600

# Exchange-rate provider. mock is deterministic and safe for local development.
# Real provider names are reserved for isolated adapters; never commit API keys.
EXCHANGE_RATE_PROVIDER=mock
EXCHANGE_RATE_PROVIDER_FALLBACK_TO_MOCK=true
EXCHANGE_RATE_PROVIDER_TIMEOUT_SECONDS=8
EXCHANGE_RATE_BASE_URL=
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_CACHE_ENABLED=true
EXCHANGE_RATE_CACHE_TTL_SECONDS=21600

# Documented for future real providers; unused in v1.
OSRM_BASE_URL=
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=
OPEN_METEO_BASE_URL=
WEATHER_API_KEY=

# --- Provider Quota & Rate-Limit Management v1 ---
# Central per-provider rate limits and Postgres-backed daily quotas. Enforcement
# is OFF by default so local development stays permissive; enable in staging/prod.
# Rate limits are per minute; a daily quota is a per-provider cap across all of
# that provider's operations. For both, 0 means unlimited. Mock providers are
# unlimited by default but their usage is still tracked when limits are enabled.
PROVIDER_LIMITS_ENABLED=false
# false: on quota-store failure, block real calls and return a controlled error.
# true: allow calls if the limiter/quota store fails. Recommended false in prod.
PROVIDER_LIMITS_FAIL_OPEN=true
PROVIDER_LIMITS_TIMEZONE=UTC
# Optional bounded wait for a rate-limit token, in milliseconds. 0 = fail fast.
PROVIDER_RATE_LIMIT_MAX_WAIT_MS=0

# Foursquare (places): place_search, place_details
FOURSQUARE_RATE_LIMIT_PER_MINUTE=50
FOURSQUARE_RATE_LIMIT_BURST=10
FOURSQUARE_DAILY_QUOTA=900

# OpenRouteService (routes): route_estimate
ORS_RATE_LIMIT_PER_MINUTE=30
ORS_RATE_LIMIT_BURST=5
ORS_DAILY_QUOTA=1500

# OpenWeatherMap (weather): weather_forecast
OPENWEATHER_RATE_LIMIT_PER_MINUTE=60
OPENWEATHER_RATE_LIMIT_BURST=10
OPENWEATHER_DAILY_QUOTA=1000

# Google Calendar (calendar): calendar_event_create/update/delete/sync
GOOGLE_CALENDAR_RATE_LIMIT_PER_MINUTE=30
GOOGLE_CALENDAR_RATE_LIMIT_BURST=5
GOOGLE_CALENDAR_DAILY_QUOTA=1000

# Exchange-rate provider: exchange_rate_latest, exchange_rate_convert
EXCHANGE_RATE_LIMIT_PER_MINUTE=30
EXCHANGE_RATE_LIMIT_BURST=5
EXCHANGE_RATE_DAILY_QUOTA=1000

# Price provider: price_estimate
PRICE_PROVIDER_RATE_LIMIT_PER_MINUTE=60
PRICE_PROVIDER_RATE_LIMIT_BURST=10
PRICE_PROVIDER_DAILY_QUOTA=1000

# --- Real Availability Layer v1 ---
# V1 never sells tickets in-app. It returns availability estimates/options and
# links users to external provider websites. Mock is deterministic and local.
AVAILABILITY_ENABLED=true
AVAILABILITY_PROVIDER=mock
AVAILABILITY_FALLBACK_TO_MOCK=true
AVAILABILITY_PROVIDER_TIMEOUT_SECONDS=8
AVAILABILITY_CACHE_ENABLED=true
AVAILABILITY_CACHE_TTL_SECONDS=900
AVAILABILITY_DEFAULT_CURRENCY=EUR
GETYOURGUIDE_API_KEY=
GETYOURGUIDE_BASE_URL=
VIATOR_API_KEY=
VIATOR_BASE_URL=
TIQETS_API_KEY=
TIQETS_BASE_URL=

# Availability provider: availability_search
AVAILABILITY_RATE_LIMIT_PER_MINUTE=30
AVAILABILITY_RATE_LIMIT_BURST=5
AVAILABILITY_DAILY_QUOTA=500
