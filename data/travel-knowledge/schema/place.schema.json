{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Curated travel place",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "category", "sourceKey", "confidence"],
  "properties": {
    "name": {"type": "string", "minLength": 1, "maxLength": 240},
    "category": {"enum": ["landmark", "museum", "park", "neighborhood", "viewpoint", "market", "restaurant", "cafe", "activity", "nature", "transport", "other"]},
    "subcategory": {"type": "string", "maxLength": 120},
    "lat": {"type": "number", "minimum": -90, "maximum": 90},
    "lng": {"type": "number", "minimum": -180, "maximum": 180},
    "address": {"type": "string", "maxLength": 500},
    "neighborhood": {"type": "string", "maxLength": 160},
    "aliases": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 240}, "maxItems": 20},
    "tags": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 80}, "maxItems": 30},
    "typicalDurationMinutes": {"type": "integer", "minimum": 5, "maximum": 720},
    "priceLevel": {"enum": ["free", "low", "medium", "high", "unknown"]},
    "outdoor": {"type": "boolean"},
    "rainFriendly": {"type": "boolean"},
    "familyFriendly": {"type": "boolean"},
    "bestTimeOfDay": {"type": "array", "items": {"enum": ["morning", "afternoon", "evening", "night"]}, "uniqueItems": true},
    "avoidIf": {"type": "array", "items": {"type": "string", "maxLength": 200}, "maxItems": 10},
    "sourceKey": {"type": "string", "minLength": 1, "maxLength": 120},
    "sourceUrl": {"type": "string", "format": "uri", "maxLength": 2000},
    "licenseName": {"type": "string", "maxLength": 300},
    "attribution": {"type": "string", "maxLength": 500},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
