{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Curated travel destination",
  "type": "object",
  "additionalProperties": false,
  "required": ["canonicalName", "countryCode", "countryName", "aliases", "tags", "places"],
  "properties": {
    "canonicalName": {"type": "string", "minLength": 1, "maxLength": 160},
    "countryCode": {"type": "string", "pattern": "^[A-Z]{2}$"},
    "countryName": {"type": "string", "minLength": 1, "maxLength": 160},
    "regionName": {"type": "string", "maxLength": 160},
    "lat": {"type": "number", "minimum": -90, "maximum": 90},
    "lng": {"type": "number", "minimum": -180, "maximum": 180},
    "aliases": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 160}, "maxItems": 30},
    "tags": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 80}, "maxItems": 30},
    "places": {"type": "array", "items": {"$ref": "place.schema.json"}, "minItems": 1, "maxItems": 200}
  }
}
