FROM node:22-alpine AS deps

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-alpine AS builder

WORKDIR /app

ARG NEXT_PUBLIC_APP_ENV=local
ARG NEXT_PUBLIC_AUTH_SERVICE_URL
ARG NEXT_PUBLIC_TRIP_SERVICE_URL
ARG NEXT_PUBLIC_USER_SERVICE_URL
ARG NEXT_PUBLIC_EXTERNAL_INTEGRATIONS_SERVICE_URL
ARG NEXT_PUBLIC_NOTIFICATION_SERVICE_URL
ARG NEXT_PUBLIC_WORKER_SERVICE_URL

ENV NEXT_TELEMETRY_DISABLED=1
ENV NEXT_PUBLIC_APP_ENV=$NEXT_PUBLIC_APP_ENV \
    NEXT_PUBLIC_AUTH_SERVICE_URL=$NEXT_PUBLIC_AUTH_SERVICE_URL \
    NEXT_PUBLIC_TRIP_SERVICE_URL=$NEXT_PUBLIC_TRIP_SERVICE_URL \
    NEXT_PUBLIC_USER_SERVICE_URL=$NEXT_PUBLIC_USER_SERVICE_URL \
    NEXT_PUBLIC_EXTERNAL_INTEGRATIONS_SERVICE_URL=$NEXT_PUBLIC_EXTERNAL_INTEGRATIONS_SERVICE_URL \
    NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=$NEXT_PUBLIC_NOTIFICATION_SERVICE_URL \
    NEXT_PUBLIC_WORKER_SERVICE_URL=$NEXT_PUBLIC_WORKER_SERVICE_URL

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build

FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000

COPY --chown=node:node package.json package-lock.json ./
COPY --chown=node:node --from=deps /app/node_modules ./node_modules
RUN npm prune --omit=dev

COPY --chown=node:node --from=builder /app/.next ./.next

USER node
EXPOSE 3000

CMD ["npm", "run", "start", "--", "--hostname", "0.0.0.0"]
