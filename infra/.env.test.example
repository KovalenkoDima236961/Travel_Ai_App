# Deterministic, mock-only values for the isolated `test` Compose profile.
# These values are intentionally public and must never be reused outside tests.
APP_ENV=test
NEXT_PUBLIC_APP_ENV=test
COMPOSE_PROFILES=test
COMPOSE_ENV_FILE=.env.test.example
LOG_LEVEL=INFO

# The test project uses distinct host ports; container-to-container ports stay standard.
POSTGRES_DB=trip_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres-test-only
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_PUBLISHED_PORT=15432
POSTGRES_MIN_CONNS=1
POSTGRES_MAX_CONNS=5
AUTH_POSTGRES_DB=auth_service
USER_POSTGRES_DB=user_service
NOTIFICATION_POSTGRES_DB=notification_service
EXTERNAL_INTEGRATIONS_POSTGRES_DB=external_integrations_service
AUTH_DATABASE_URL=postgres://postgres:postgres-test-only@postgres:5432/auth_service?sslmode=disable
USER_DATABASE_URL=postgres://postgres:postgres-test-only@postgres:5432/user_service?sslmode=disable
NOTIFICATION_DATABASE_URL=postgres://postgres:postgres-test-only@postgres:5432/notification_service?sslmode=disable

RABBITMQ_USER=test
RABBITMQ_PASSWORD=test
RABBITMQ_URL=amqp://test:test@rabbitmq:5672/
RABBITMQ_PUBLISHED_PORT=25672
RABBITMQ_MANAGEMENT_PUBLISHED_PORT=25673
RABBITMQ_METRICS_PUBLISHED_PORT=25692
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_MANAGEMENT_USER=test
RABBITMQ_MANAGEMENT_PASSWORD=test

JWT_ACCESS_SECRET=test-access-secret-not-for-production
JWT_REFRESH_SECRET=test-refresh-secret-not-for-production
INTERNAL_SERVICE_TOKEN=test-internal-token-not-for-production
NOTIFICATION_SERVICE_TOKEN=test-internal-token-not-for-production
OPS_INTERNAL_SERVICE_TOKEN=test-ops-token-not-for-production
PUBLIC_SHARE_ACCESS_SECRET=test-share-secret-not-for-production
CALENDAR_TOKEN_ENCRYPTION_KEY=test-calendar-key-32-bytes-long!

TRIP_SERVICE_PORT=18080
AUTH_SERVICE_PORT=18082
USER_SERVICE_PORT=18083
EXTERNAL_INTEGRATIONS_SERVICE_PORT=18084
NOTIFICATION_SERVICE_PORT=18086
WORKER_SERVICE_PORT=18090
WEB_APP_PORT=13000
AI_TEST_SERVICE_PORT=18000

TRIP_HTTP_ADDRESS=:8080
AUTH_HTTP_ADDR=:8082
AUTH_HTTP_ADDRESS=:8082
USER_HTTP_ADDRESS=:8083
EXTERNAL_INTEGRATIONS_HTTP_ADDR=:8084
NOTIFICATION_HTTP_ADDRESS=:8086
WORKER_HTTP_ADDR=:8090

PUBLIC_WEB_BASE_URL=http://127.0.0.1:13000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:13000,http://localhost:13000
NEXT_PUBLIC_AUTH_SERVICE_URL=http://127.0.0.1:18082
NEXT_PUBLIC_TRIP_SERVICE_URL=http://127.0.0.1:18080
NEXT_PUBLIC_USER_SERVICE_URL=http://127.0.0.1:18083
NEXT_PUBLIC_EXTERNAL_INTEGRATIONS_SERVICE_URL=http://127.0.0.1:18084
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=http://127.0.0.1:18086
NEXT_PUBLIC_WORKER_SERVICE_URL=http://127.0.0.1:18090
TRIP_SERVICE_INTERNAL_URL=http://trip-service:8080
USER_SERVICE_INTERNAL_URL=http://user-service:8083
NOTIFICATION_SERVICE_INTERNAL_URL=http://notification-service:8086
EXTERNAL_INTEGRATIONS_SERVICE_INTERNAL_URL=http://external-integrations-service:8084
WORKER_SERVICE_INTERNAL_URL=http://worker-service:8090
AUTH_SERVICE_INTERNAL_URL=http://auth-service:8082

AUTH_REQUIRED=true
TRIP_ITINERARY_GENERATOR_MODE=mock
AI_ITINERARY_GENERATOR_MODE=mock
AI_PLANNING_SERVICE_URL=http://ai-planning-service-test:8000
RAG_ENABLED=false
DESTINATION_CONTEXT_ENABLED=true
OLLAMA_FALLBACK_TO_MOCK=true

PLACE_PROVIDER=mock
PLACE_PROVIDER_FALLBACK_TO_MOCK=true
ROUTE_PROVIDER=mock
ROUTE_PROVIDER_FALLBACK_TO_MOCK=true
WEATHER_PROVIDER=mock
WEATHER_PROVIDER_FALLBACK_TO_MOCK=true
EXCHANGE_RATE_PROVIDER=mock
EXCHANGE_RATE_PROVIDER_FALLBACK_TO_MOCK=true
PRICE_PROVIDER=mock
PRICE_PROVIDER_FALLBACK_TO_MOCK=true
AVAILABILITY_PROVIDER=mock
AVAILABILITY_FALLBACK_TO_MOCK=true
CALENDAR_PROVIDER=mock
GOOGLE_CALENDAR_ENABLED=false
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_PROVIDER=mock
WEB_PUSH_ENABLED=false
FILE_SCANNING_ENABLED=false
FILE_SCANNING_FAIL_OPEN=false

GENERATION_JOBS_ENABLED=true
GENERATION_JOB_DISPATCH_MODE=queue
GENERATION_JOB_WORKER_ENABLED=true
GENERATION_JOB_WORKER_POLL_INTERVAL_SECONDS=1
GENERATION_JOBS_RETRY_DELAY_SECONDS=1
NOTIFICATION_SSE_ENABLED=true
OPS_DASHBOARD_ENABLED=false
