# Local Docker Compose settings for infra/docker-compose.yml.
# Copy this file to infra/.env before starting the stack.

APP_ENV=local
LOG_LEVEL=INFO
PUBLIC_API_BASE_URL=http://localhost:3000/api

# PostgreSQL
POSTGRES_DB=trip_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@postgres:5432/trip_service?sslmode=disable
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONNS=10
POSTGRES_MIG_PATH=/app/migrations

# Trip Service
TRIP_HTTP_ADDRESS=:8080
TRIP_HTTP_WRITE_TIMEOUT=150s
TRIP_ITINERARY_GENERATOR_MODE=http
AI_PLANNING_SERVICE_URL=http://ai-planning-service:8000
AI_PLANNING_TIMEOUT_SECONDS=120
USER_SERVICE_URL=http://user-service:8083
USER_CONTEXT_ENABLED=true
USER_CONTEXT_TIMEOUT_SECONDS=5
USER_CONTEXT_FAIL_OPEN=true
EXTERNAL_INTEGRATIONS_SERVICE_URL=http://external-integrations-service:8084
WEATHER_CONTEXT_ENABLED=true
WEATHER_CONTEXT_TIMEOUT_SECONDS=5
WEATHER_CONTEXT_FAIL_OPEN=true
PLACE_ENRICHMENT_ENABLED=true
PLACE_ENRICHMENT_FAIL_OPEN=true
PLACE_ENRICHMENT_TIMEOUT_SECONDS=5
PLACE_ENRICHMENT_MIN_CONFIDENCE=0.75
PLACE_ENRICHMENT_MAX_ITEMS=20
PLACE_ENRICHMENT_OVERWRITE_EXISTING=false
PRICE_ENRICHMENT_ENABLED=true
PRICE_ENRICHMENT_FAIL_OPEN=true
PRICE_ENRICHMENT_TIMEOUT_SECONDS=8
PRICE_ENRICHMENT_OVERWRITE_AI_COSTS=false
PRICE_ENRICHMENT_OVERWRITE_MANUAL_COSTS=false
PRICE_ENRICHMENT_MIN_MATCH_CONFIDENCE=0.55
PRICE_ENRICHMENT_MAX_ITEMS=30
PRICE_ENRICHMENT_DEFAULT_CURRENCY=EUR
PUBLIC_WEB_BASE_URL=http://localhost:3000
PUBLIC_SHARING_ENABLED=true
SHARE_TOKEN_BYTES=32
# Dev-only public share unlock token secret; use a different strong secret outside local development.
PUBLIC_SHARE_ACCESS_SECRET=dev-public-share-secret-change-me
PUBLIC_SHARE_ACCESS_TTL_MINUTES=60
TRIP_PRESENCE_ENABLED=true
TRIP_PRESENCE_HEARTBEAT_SECONDS=25
TRIP_PRESENCE_STALE_AFTER_SECONDS=60
TRIP_PRESENCE_MAX_CONNECTIONS_PER_USER_PER_TRIP=5
TRIP_PRESENCE_SEND_FULL_SNAPSHOT=true
TRIP_ACTIVITY_STREAM_ENABLED=true
TRIP_ACTIVITY_STREAM_HEARTBEAT_SECONDS=25
TRIP_ACTIVITY_STREAM_WRITE_TIMEOUT_SECONDS=10
TRIP_ACTIVITY_STREAM_MAX_CONNECTIONS_PER_USER_PER_TRIP=5
TRIP_ACTIVITY_STREAM_CLIENT_BUFFER_SIZE=20
TRIP_EDIT_LOCKS_ENABLED=true
TRIP_EDIT_LOCK_TTL_SECONDS=180
TRIP_EDIT_LOCK_RENEW_SECONDS=45
TRIP_EDIT_LOCK_STALE_CLEANUP_SECONDS=30
GENERATION_JOBS_ENABLED=true
GENERATION_JOB_DISPATCH_MODE=queue
GENERATION_JOB_WORKER_ENABLED=true
GENERATION_JOB_WORKER_POLL_INTERVAL_SECONDS=2
GENERATION_JOB_WORKER_MAX_CONCURRENT=1
GENERATION_JOB_MAX_RUNNING_SECONDS=600
GENERATION_JOB_PUBLISH_TIMEOUT_SECONDS=5
GENERATION_JOB_PUBLISH_FAIL_OPEN=false
GENERATION_JOB_FAIL_OPEN_NOTIFICATIONS=true
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=trip.jobs.exchange
RABBITMQ_DLX=trip.jobs.dlx
GENERATION_JOBS_QUEUE=trip.generation.jobs
GENERATION_JOBS_ROUTING_KEY=trip.generation
GENERATION_JOBS_DEAD_LETTER_QUEUE=trip.generation.dead_letter
GENERATION_JOBS_DEAD_LETTER_ROUTING_KEY=trip.generation.dead
GENERATION_JOBS_RETRY_QUEUE=trip.generation.retry
GENERATION_JOBS_RETRY_ROUTING_KEY=trip.generation.retry
GENERATION_JOBS_PREFETCH=1
GENERATION_JOBS_MAX_ATTEMPTS=3
GENERATION_JOBS_RETRY_DELAY_SECONDS=10

# Admin/Ops Dashboard. Disabled by default; set OPS_ADMIN_EMAILS to a
# comma-separated allowlist before enabling.
OPS_DASHBOARD_ENABLED=false
OPS_ADMIN_EMAILS=
OPS_INTERNAL_SERVICE_TOKEN=dev-internal-service-token
OPS_STALE_RUNNING_JOB_SECONDS=900

WORKER_ENABLED=true
WORKER_HTTP_ADDR=:8090
WORKER_SHUTDOWN_TIMEOUT_SECONDS=30
WORKER_CONCURRENCY=1
WORKER_SERVICE_PORT=8090
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_MANAGEMENT_USER=guest
RABBITMQ_MANAGEMENT_PASSWORD=guest
BUDGET_CONVERSION_ENABLED=true
BUDGET_CONVERSION_FAIL_OPEN=true
EXCHANGE_RATE_CLIENT_TIMEOUT_SECONDS=8
AUTH_REQUIRED=true
AUTH_HEADER_NAME=Authorization
DEV_USER_ID=00000000-0000-0000-0000-000000000001
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Trip Service -> Notification Service integration
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_FAIL_OPEN=true
NOTIFICATION_SERVICE_URL=http://notification-service:8086
NOTIFICATION_SERVICE_TOKEN=dev-internal-service-token
NOTIFICATION_SERVICE_TIMEOUT_SECONDS=3

# Auth Service
AUTH_SERVICE_PORT=8082
AUTH_SERVICE_URL=http://localhost:8082
AUTH_SERVICE_INTERNAL_URL=http://auth-service:8082
AUTH_HTTP_ADDR=:8082
AUTH_HTTP_ADDRESS=:8082
AUTH_DATABASE_URL=postgres://postgres:postgres@postgres:5432/auth_service?sslmode=disable
AUTH_DATABASE_MIGRATIONS_PATH=/app/migrations
AUTH_POSTGRES_DB=auth_service
AUTH_POSTGRES_MIG_PATH=/app/migrations
JWT_ACCESS_SECRET=change-me-in-development
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
AUTH_CORS_ALLOWED_METHODS=GET,POST,OPTIONS

# User Service
USER_SERVICE_PORT=8083
USER_HTTP_ADDRESS=:8083
USER_DATABASE_URL=postgres://postgres:postgres@postgres:5432/user_service?sslmode=disable
USER_POSTGRES_DB=user_service
USER_POSTGRES_MIG_PATH=/app/migrations
USER_CORS_ALLOWED_METHODS=GET,PUT,PATCH,OPTIONS

# Notification Service
# Shared service-to-service token used by Trip Service to authenticate to the
# Notification Service internal endpoint. Use a strong, unique value outside
# local development.
INTERNAL_SERVICE_TOKEN=dev-internal-service-token
NOTIFICATION_SERVICE_PORT=8086
NOTIFICATION_HTTP_ADDRESS=:8086
# Notification Service uses its own logical database on the shared Postgres.
# (Switchable to a dedicated Postgres container later via NOTIFICATION_DATABASE_URL.)
NOTIFICATION_DATABASE_URL=postgres://postgres:postgres@postgres:5432/notification_service?sslmode=disable
NOTIFICATION_POSTGRES_DB=notification_service
NOTIFICATION_POSTGRES_MIG_PATH=/app/migrations
NOTIFICATION_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
NOTIFICATION_SSE_ENABLED=true
NOTIFICATION_SSE_HEARTBEAT_SECONDS=25
NOTIFICATION_SSE_WRITE_TIMEOUT_SECONDS=10
NOTIFICATION_SSE_MAX_CONNECTIONS_PER_USER=5

# Notification Service -> Email (v1)
# Mock provider sends NO external mail and is the safe local-dev default.
# Switch EMAIL_PROVIDER=smtp and fill SMTP_* to deliver real email.
# NEVER commit real SMTP credentials.
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_FAIL_OPEN=true
EMAIL_PROVIDER=mock
EMAIL_NOTIFICATION_TYPES=collaboration_invited,comment_created,collaborator_role_changed,collaborator_removed
# Recipient email lookup. Auth Service owns email in v1; the lookup presents
# INTERNAL_SERVICE_TOKEN to POST /internal/users/batch.
USER_LOOKUP_TIMEOUT_SECONDS=5
# SMTP settings (only used when EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@localhost
SMTP_FROM_NAME=AI Travel Planner
SMTP_USE_TLS=true

# Browser Web Push (VAPID). Generate local keys with:
#   npx web-push generate-vapid-keys
# WEB_PUSH_VAPID_PUBLIC_KEY is safe to expose to browsers; keep the private key
# secret and out of git.
WEB_PUSH_ENABLED=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:support@example.com
WEB_PUSH_TIMEOUT_SECONDS=8
WEB_PUSH_TTL_SECONDS=3600
WEB_PUSH_URGENCY=normal
WEB_PUSH_FAIL_OPEN=true

# External Integrations Service
EXTERNAL_INTEGRATIONS_SERVICE_PORT=8084
EXTERNAL_INTEGRATIONS_HTTP_ADDR=:8084
EXTERNAL_INTEGRATIONS_POSTGRES_DB=external_integrations_service
EXTERNAL_INTEGRATIONS_POSTGRES_MIG_PATH=/app/migrations
PLACE_PROVIDER=mock
PLACE_PROVIDER_FALLBACK_TO_MOCK=true
FOURSQUARE_API_KEY=
FOURSQUARE_BASE_URL=https://api.foursquare.com/v3
FOURSQUARE_TIMEOUT_SECONDS=8
# Routing provider: mock (default and fallback) | ors (OpenRouteService).
# Set ROUTE_PROVIDER=ors and ORS_API_KEY to use real routing. Never commit keys.
ROUTE_PROVIDER=mock
ROUTE_PROVIDER_FALLBACK_TO_MOCK=true
ROUTE_PROVIDER_TIMEOUT_SECONDS=8
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org
ORS_PROFILE_WALKING=foot-walking
ORS_PROFILE_DRIVING=driving-car
ORS_PROFILE_CYCLING=cycling-regular
ROUTE_CACHE_ENABLED=true
ROUTE_CACHE_TTL_SECONDS=21600
# Weather provider: mock (default and fallback) | openweathermap (OpenWeatherMap).
# Set WEATHER_PROVIDER=openweathermap and OPENWEATHER_API_KEY to use real weather.
WEATHER_PROVIDER=mock
WEATHER_PROVIDER_FALLBACK_TO_MOCK=true
WEATHER_PROVIDER_TIMEOUT_SECONDS=8
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
OPENWEATHER_UNITS=metric
WEATHER_CACHE_ENABLED=true
WEATHER_CACHE_TTL_SECONDS=3600
# Exchange-rate provider: mock is deterministic and safe for local development.
EXCHANGE_RATE_PROVIDER=mock
EXCHANGE_RATE_PROVIDER_FALLBACK_TO_MOCK=true
EXCHANGE_RATE_PROVIDER_TIMEOUT_SECONDS=8
EXCHANGE_RATE_BASE_URL=
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_CACHE_ENABLED=true
EXCHANGE_RATE_CACHE_TTL_SECONDS=21600
# Attraction/ticket price provider. Mock is deterministic and approximate.
PRICE_PROVIDER=mock
PRICE_PROVIDER_FALLBACK_TO_MOCK=true
PRICE_PROVIDER_TIMEOUT_SECONDS=8
PRICE_CACHE_ENABLED=true
PRICE_CACHE_TTL_SECONDS=86400
PRICE_API_BASE_URL=
PRICE_API_KEY=
# Advanced Availability Provider Adapters v1. Mock is the default/fallback and
# only links to external provider URLs; no in-app payments or bookings are
# supported. Set AVAILABILITY_PROVIDER=ticketmaster (+ TICKETMASTER_API_KEY) to
# discover real events. Results are provider availability, not booking guarantees.
AVAILABILITY_ENABLED=true
AVAILABILITY_PROVIDER=mock
AVAILABILITY_FALLBACK_TO_MOCK=true
AVAILABILITY_PROVIDER_TIMEOUT_SECONDS=8
AVAILABILITY_CACHE_ENABLED=true
AVAILABILITY_CACHE_TTL_SECONDS=900
AVAILABILITY_DEFAULT_CURRENCY=EUR
# Conservative matching thresholds shared by every real provider adapter. A match
# below MIN is never shown as available (status becomes unknown); below LOW it is
# a "possible match" the user must confirm before applying. MAX_OPTIONS caps the
# returned option count.
AVAILABILITY_MIN_MATCH_CONFIDENCE=0.55
AVAILABILITY_LOW_CONFIDENCE_THRESHOLD=0.65
AVAILABILITY_MAX_OPTIONS=10
# Ticketmaster Discovery API (events/concerts/sports/theatre). Backend-only key.
# Rate-limit and daily-quota controls are shared with the AVAILABILITY_* provider
# limit bucket below.
TICKETMASTER_API_KEY=
TICKETMASTER_BASE_URL=https://app.ticketmaster.com/discovery/v2
TICKETMASTER_TIMEOUT_SECONDS=8
TICKETMASTER_CACHE_TTL_SECONDS=1800
# Tours/activities adapters (planned; placeholders only in v1).
GETYOURGUIDE_API_KEY=
GETYOURGUIDE_BASE_URL=
VIATOR_API_KEY=
VIATOR_BASE_URL=
TIQETS_API_KEY=
TIQETS_BASE_URL=
# Provider quota & rate-limit management (v1). Off/permissive by default; enable
# in staging/prod. Rate limits are per minute; daily quotas cap a provider across
# all of its operations. 0 means unlimited. See per-environment example files.
PROVIDER_LIMITS_ENABLED=false
PROVIDER_LIMITS_FAIL_OPEN=true
PROVIDER_LIMITS_TIMEZONE=UTC
PROVIDER_RATE_LIMIT_MAX_WAIT_MS=0
FOURSQUARE_RATE_LIMIT_PER_MINUTE=50
FOURSQUARE_RATE_LIMIT_BURST=10
FOURSQUARE_DAILY_QUOTA=900
ORS_RATE_LIMIT_PER_MINUTE=30
ORS_RATE_LIMIT_BURST=5
ORS_DAILY_QUOTA=1500
OPENWEATHER_RATE_LIMIT_PER_MINUTE=60
OPENWEATHER_RATE_LIMIT_BURST=10
OPENWEATHER_DAILY_QUOTA=1000
GOOGLE_CALENDAR_RATE_LIMIT_PER_MINUTE=30
GOOGLE_CALENDAR_RATE_LIMIT_BURST=5
GOOGLE_CALENDAR_DAILY_QUOTA=1000
EXCHANGE_RATE_LIMIT_PER_MINUTE=30
EXCHANGE_RATE_LIMIT_BURST=5
EXCHANGE_RATE_DAILY_QUOTA=1000
PRICE_PROVIDER_RATE_LIMIT_PER_MINUTE=60
PRICE_PROVIDER_RATE_LIMIT_BURST=10
PRICE_PROVIDER_DAILY_QUOTA=1000
# Shared by every real availability provider (Ticketmaster and future adapters).
AVAILABILITY_RATE_LIMIT_PER_MINUTE=30
AVAILABILITY_RATE_LIMIT_BURST=5
AVAILABILITY_DAILY_QUOTA=500
EXTERNAL_INTEGRATIONS_CORS_ALLOWED_METHODS=GET,POST,DELETE,OPTIONS
GOOGLE_PLACES_API_KEY=
MAPBOX_API_KEY=
GOOGLE_CALENDAR_ENABLED=true
CALENDAR_PROVIDER=mock
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8084/calendar/google/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events
CALENDAR_TOKEN_ENCRYPTION_KEY=dev-calendar-token-key-32-bytes!
CALENDAR_OAUTH_STATE_TTL_SECONDS=600
DEFAULT_CALENDAR_TIMEZONE=Europe/Bratislava
CALENDAR_SYNC_ENABLED=true
CALENDAR_SYNC_TIMEOUT_SECONDS=30
# Documented for future real providers; unused in v1.
OSRM_BASE_URL=
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=
OPEN_METEO_BASE_URL=
WEATHER_API_KEY=

# Web App
WEB_APP_PORT=3000
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8082
NEXT_PUBLIC_TRIP_SERVICE_URL=http://localhost:8080
NEXT_PUBLIC_USER_SERVICE_URL=http://localhost:8083
NEXT_PUBLIC_EXTERNAL_INTEGRATIONS_SERVICE_URL=http://localhost:8084
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=http://localhost:8086
NEXT_PUBLIC_WORKER_SERVICE_URL=http://localhost:8090
TRIP_SERVICE_INTERNAL_URL=http://trip-service:8080
USER_SERVICE_INTERNAL_URL=http://user-service:8083
NOTIFICATION_SERVICE_INTERNAL_URL=http://notification-service:8086
EXTERNAL_INTEGRATIONS_SERVICE_INTERNAL_URL=http://external-integrations-service:8084
WORKER_SERVICE_INTERNAL_URL=http://worker-service:8090

# AI Planning Service
AI_HTTP_HOST=0.0.0.0
AI_HTTP_PORT=8000
AI_ITINERARY_GENERATOR_MODE=ollama

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=2048
OLLAMA_FALLBACK_TO_MOCK=true
OLLAMA_REPAIR_ENABLED=true
OLLAMA_REPAIR_ATTEMPTS=1
LOG_LLM_PAYLOADS=false
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=60

# Destination context
DESTINATION_CONTEXT_ENABLED=true
DESTINATION_CONTEXT_DIR=app/data/destinations

# Local RAG
RAG_ENABLED=true
RAG_KNOWLEDGE_DIR=app/data/knowledge
RAG_CHROMA_DIR=app/data/chroma
RAG_COLLECTION_NAME=travel_knowledge
RAG_TOP_K=5
RAG_MIN_SCORE=0.0
ANONYMIZED_TELEMETRY=false
