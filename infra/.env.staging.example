# Staging profile. Use staging URLs and strong non-production secrets.

# Global
APP_ENV=staging
LOG_LEVEL=INFO
PUBLIC_WEB_BASE_URL=https://staging.app.example.com
PUBLIC_API_BASE_URL=https://staging.app.example.com/api

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trip_service
POSTGRES_USER=travel_ai
POSTGRES_PASSWORD=change_me_to_secure_random_32_bytes_min
DATABASE_URL=postgres://travel_ai:change_me_to_secure_random_32_bytes_min@postgres:5432/trip_service?sslmode=disable
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONNS=20
POSTGRES_MIG_PATH=/app/migrations

# RabbitMQ
RABBITMQ_URL=amqp://travel_ai:change_me_to_secure_random_32_bytes_min@rabbitmq:5672/
RABBITMQ_USER=travel_ai
RABBITMQ_PASSWORD=change_me_to_secure_random_32_bytes_min
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_MANAGEMENT_USER=travel_ai
RABBITMQ_MANAGEMENT_PASSWORD=change_me_to_secure_random_32_bytes_min

# Auth/JWT
JWT_ACCESS_SECRET=change_me_to_secure_random_32_bytes_min
JWT_REFRESH_SECRET=change_me_to_secure_random_32_bytes_min
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Internal service auth
INTERNAL_SERVICE_TOKEN=change_me_to_secure_random_32_bytes_min
INTERNAL_SERVICE_TOKENS=
NOTIFICATION_SERVICE_TOKEN=change_me_to_secure_random_32_bytes_min
OPS_INTERNAL_SERVICE_TOKEN=change_me_to_secure_random_32_bytes_min

# CORS
CORS_ALLOWED_ORIGINS=https://staging.app.example.com
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=10
AUTH_REGISTER_RATE_LIMIT_PER_MINUTE=10
AUTH_REFRESH_RATE_LIMIT_PER_MINUTE=30
SHARE_UNLOCK_RATE_LIMIT_PER_MINUTE=5
PUBLIC_SHARE_ACCESS_RATE_LIMIT_PER_MINUTE=120
RECEIPT_UPLOAD_RATE_LIMIT_PER_MINUTE=20
RECEIPT_UPLOAD_MAX_BYTES=10485760
RECEIPT_UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf
RECEIPT_UPLOAD_ALLOWED_EXT=.jpg,.jpeg,.png,.webp,.pdf
FILE_SCANNING_ENABLED=false
FILE_SCANNING_FAIL_OPEN=false
AI_PROMPT_LOGGING_ENABLED=false
AI_PROMPT_LOGGING_REDACTED_ONLY=true
AI_OBSERVABILITY_ENABLED=true
AI_OBSERVABILITY_TRACE_EVENTS_ENABLED=true
AI_OBSERVABILITY_STORE_REDACTED_PROMPTS=false
AI_OBSERVABILITY_STORE_REDACTED_RESPONSES=false
AI_OBSERVABILITY_MAX_PROMPT_SNAPSHOT_CHARS=12000
AI_OBSERVABILITY_RETENTION_DAYS=30
AI_OBSERVABILITY_FAIL_OPEN=true
AI_OBSERVABILITY_DEBUG_LOCAL_ONLY=true
AI_OBSERVABILITY_REDACTION_ENABLED=true
OFFLINE_CACHE_MAX_AGE_DAYS=30

# Web Push
WEB_PUSH_ENABLED=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:staging-support@example.com

# Email
EMAIL_PROVIDER=mock
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_FAIL_OPEN=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@staging.app.example.com

# Notification digest and noise control
NOTIFICATION_DEDUPE_WINDOW_MINUTES=30
NOTIFICATION_GROUPING_WINDOW_MINUTES=60
NOTIFICATION_DIGEST_MAX_ATTEMPTS=3
NOTIFICATION_DIGEST_RETRY_DELAY_SECONDS=300
NOTIFICATION_DIGEST_RETENTION_DAYS=30
NOTIFICATION_DIGEST_WORKER_ENABLED=true
NOTIFICATION_DIGEST_WORKER_POLL_INTERVAL_SECONDS=30
NOTIFICATION_DIGEST_WORKER_BATCH_SIZE=100
NOTIFICATION_DIGEST_WORKER_TIMEOUT_SECONDS=15

# Google Calendar
GOOGLE_CALENDAR_ENABLED=false
CALENDAR_PROVIDER=mock
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=https://staging.api.example.com/calendar/google/callback
CALENDAR_TOKEN_ENCRYPTION_KEY=change_me_32_byte_calendar_key__

# External providers
PLACE_PROVIDER=mock
FOURSQUARE_API_KEY=
ROUTE_PROVIDER=mock
ORS_API_KEY=
WEATHER_PROVIDER=mock
OPENWEATHER_API_KEY=
EXCHANGE_RATE_PROVIDER=mock
EXCHANGE_RATE_API_KEY=
PRICE_PROVIDER=mock
BUDGET_CONFIDENCE_ENABLED=true
BUDGET_CONFIDENCE_CACHE_TTL_SECONDS=60
BUDGET_CONFIDENCE_FAIL_OPEN=true
BUDGET_CONFIDENCE_LARGE_EXPENSE_RECEIPT_THRESHOLD=100
BUDGET_CONFIDENCE_ACTUAL_SPEND_HIGH_THRESHOLD_PERCENT=80
BUDGET_CONFIDENCE_PLANNED_ACTUAL_GAP_WARNING_PERCENT=20
BUDGET_CONFIDENCE_PLANNED_ACTUAL_GAP_HIGH_PERCENT=40
AVAILABILITY_ENABLED=true
AVAILABILITY_PROVIDER=mock
AVAILABILITY_FALLBACK_TO_MOCK=true
AVAILABILITY_CACHE_TTL_SECONDS=900
AVAILABILITY_DEFAULT_CURRENCY=EUR
GETYOURGUIDE_API_KEY=
GETYOURGUIDE_BASE_URL=
VIATOR_API_KEY=
VIATOR_BASE_URL=
TIQETS_API_KEY=
TIQETS_BASE_URL=

# Provider quota & rate-limit management (v1). Enabled in staging; fail-open so a
# quota-store hiccup does not block the platform. 0 means unlimited.
PROVIDER_LIMITS_ENABLED=true
PROVIDER_LIMITS_FAIL_OPEN=true
PROVIDER_LIMITS_TIMEZONE=UTC
PROVIDER_RATE_LIMIT_MAX_WAIT_MS=0
FOURSQUARE_RATE_LIMIT_PER_MINUTE=50
FOURSQUARE_RATE_LIMIT_BURST=10
FOURSQUARE_DAILY_QUOTA=900
ORS_RATE_LIMIT_PER_MINUTE=30
ORS_RATE_LIMIT_BURST=5
ORS_DAILY_QUOTA=1500
OPENWEATHER_RATE_LIMIT_PER_MINUTE=60
OPENWEATHER_RATE_LIMIT_BURST=10
OPENWEATHER_DAILY_QUOTA=1000
GOOGLE_CALENDAR_RATE_LIMIT_PER_MINUTE=30
GOOGLE_CALENDAR_RATE_LIMIT_BURST=5
GOOGLE_CALENDAR_DAILY_QUOTA=1000
EXCHANGE_RATE_LIMIT_PER_MINUTE=30
EXCHANGE_RATE_LIMIT_BURST=5
EXCHANGE_RATE_DAILY_QUOTA=1000
PRICE_PROVIDER_RATE_LIMIT_PER_MINUTE=60
PRICE_PROVIDER_RATE_LIMIT_BURST=10
PRICE_PROVIDER_DAILY_QUOTA=1000
AVAILABILITY_RATE_LIMIT_PER_MINUTE=30
AVAILABILITY_RATE_LIMIT_BURST=5
AVAILABILITY_DAILY_QUOTA=500

# Observability/Ops
OPS_DASHBOARD_ENABLED=true
OPS_ADMIN_EMAILS=ops@example.com
PROMETHEUS_RETENTION=15d
GRAFANA_ADMIN_USER=staging_ops
GRAFANA_ADMIN_PASSWORD=change_me_to_secure_random_32_bytes_min

# Service URLs
AUTH_SERVICE_URL=http://auth-service:8082
AUTH_SERVICE_INTERNAL_URL=http://auth-service:8082
USER_SERVICE_URL=http://user-service:8083
USER_SERVICE_INTERNAL_URL=http://user-service:8083
TRIP_SERVICE_INTERNAL_URL=http://trip-service:8080
NOTIFICATION_SERVICE_URL=http://notification-service:8086
NOTIFICATION_SERVICE_INTERNAL_URL=http://notification-service:8086
EXTERNAL_INTEGRATIONS_SERVICE_URL=http://external-integrations-service:8084
EXTERNAL_INTEGRATIONS_SERVICE_INTERNAL_URL=http://external-integrations-service:8084
WORKER_SERVICE_INTERNAL_URL=http://worker-service:8090
AI_PLANNING_SERVICE_URL=http://ai-planning-service:8000
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_AUTH_SERVICE_URL=https://staging-auth.example.com
NEXT_PUBLIC_TRIP_SERVICE_URL=https://staging-trip.example.com
NEXT_PUBLIC_USER_SERVICE_URL=https://staging-user.example.com
NEXT_PUBLIC_EXTERNAL_INTEGRATIONS_SERVICE_URL=https://staging-integrations.example.com
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=https://staging-notifications.example.com
NEXT_PUBLIC_WORKER_SERVICE_URL=https://staging-worker.example.com

# Jobs/workers
GENERATION_JOBS_ENABLED=true
GENERATION_JOB_DISPATCH_MODE=queue
GENERATION_JOB_WORKER_ENABLED=false
GENERATION_JOB_MAX_RUNNING_SECONDS=600
OPS_STALE_RUNNING_JOB_SECONDS=900
WORKER_ENABLED=true
WORKER_CONCURRENCY=1
WORKER_SHUTDOWN_TIMEOUT_SECONDS=45

DATA_EXPORT_ENABLED=true
RECEIPT_STORAGE_PROVIDER=local
RECEIPT_STORAGE_LOCAL_DIR=/var/app/receipts
TRIP_DATA_EXPORT_STORAGE_DIR=/var/app/exports
USER_DATA_EXPORT_STORAGE_DIR=/var/app/exports
DATA_EXPORT_TTL_HOURS=24
DATA_EXPORT_MAX_TRIP_EXPORT_MB=100
DATA_EXPORT_MAX_ACCOUNT_EXPORT_MB=250
DATA_EXPORT_INCLUDE_RECEIPT_FILES_DEFAULT=false
DATA_EXPORT_CLEANUP_ENABLED=true
DATA_EXPORT_CLEANUP_INTERVAL_MINUTES=60
ACCOUNT_EXPORT_TRIP_DATA_ENABLED=true
TRIP_EXPORT_TIMEOUT_SECONDS=60

# AI Planning
AI_ITINERARY_GENERATOR_MODE=mock
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACK_TO_MOCK=true
LOG_LLM_PAYLOADS=false
RAG_ENABLED=false
# Trip-service performance safeguards.
DB_QUERY_TIMEOUT_SECONDS=10
DB_SLOW_QUERY_THRESHOLD_MS=250
SUMMARY_CACHE_ENABLED=true
SUMMARY_CACHE_TTL_SECONDS=30
SUMMARY_CACHE_MAX_ITEMS=1000
SUMMARY_ENDPOINT_TIMEOUT_SECONDS=8
