# Staging-like profile. Copy to infra/.env.staging and replace every change_me
# value with a managed secret before use. It is mock-first and needs no provider keys.
APP_ENV=staging
APP_VERSION=0.1.0
GIT_SHA=unknown
BUILD_TIME=unknown
IMAGE_REGISTRY=travel-ai
IMAGE_TAG=0.1.0
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_GIT_SHA=unknown
NEXT_PUBLIC_BUILD_TIME=unknown

POSTGRES_DB=trip_service
POSTGRES_USER=travelai
POSTGRES_PASSWORD=change_me_to_secure_database_value_32_bytes_min
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONNS=10
POSTGRES_MIG_PATH=/app/migrations
DATABASE_URL=postgres://travelai:change_me_to_secure_database_value_32_bytes_min@postgres:5432/trip_service?sslmode=disable

RABBITMQ_USER=travelai
RABBITMQ_PASSWORD=change_me_to_secure_rabbitmq_value_32_bytes_min
RABBITMQ_URL=amqp://travelai:change_me_to_secure_rabbitmq_value_32_bytes_min@rabbitmq:5672/
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672
RABBITMQ_MANAGEMENT_USER=travelai
RABBITMQ_MANAGEMENT_PASSWORD=change_me_to_secure_rabbitmq_value_32_bytes_min
JWT_ACCESS_SECRET=change_me_to_secure_jwt_access_value_32_bytes_min
JWT_REFRESH_SECRET=change_me_to_secure_jwt_refresh_value_32_bytes_min
INTERNAL_SERVICE_TOKEN=change_me_to_secure_internal_token_value_32_bytes
NOTIFICATION_SERVICE_TOKEN=change_me_to_secure_notification_token_32_bytes
OPS_INTERNAL_SERVICE_TOKEN=change_me_to_secure_ops_token_value_32_bytes_min
PUBLIC_SHARE_ACCESS_SECRET=change_me_to_secure_share_access_value_32_bytes
CALENDAR_TOKEN_ENCRYPTION_KEY=change_me_to_secure_calendar_key_value_32_bytes
GRAFANA_ADMIN_PASSWORD=change_me_to_secure_grafana_value_32_bytes_min
GRAFANA_ADMIN_USER=travelai-admin

PUBLIC_WEB_BASE_URL=https://staging.travel-ai.invalid
PUBLIC_API_BASE_URL=https://staging.travel-ai.invalid/api
CORS_ALLOWED_ORIGINS=https://staging.travel-ai.invalid
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
TRIP_ITINERARY_GENERATOR_MODE=mock
AI_ITINERARY_GENERATOR_MODE=mock
RAG_ENABLED=false
PLACE_PROVIDER=mock
ROUTE_PROVIDER=mock
WEATHER_PROVIDER=mock
EXCHANGE_RATE_PROVIDER=mock
PRICE_PROVIDER=mock
CALENDAR_PROVIDER=mock
GOOGLE_CALENDAR_ENABLED=false
EMAIL_PROVIDER=mock
WEB_PUSH_ENABLED=false
FILE_SCANNING_ENABLED=false
FILE_SCANNING_FAIL_OPEN=false
OPS_DASHBOARD_ENABLED=false
OPS_ADMIN_EMAILS=
PUBLIC_SHARE_ACCESS_TTL_MINUTES=60
SHARE_UNLOCK_RATE_LIMIT_PER_MINUTE=5
PUBLIC_SHARE_ACCESS_RATE_LIMIT_PER_MINUTE=120
RECEIPT_UPLOAD_RATE_LIMIT_PER_MINUTE=20
RECEIPT_UPLOAD_MAX_BYTES=10485760
RECEIPT_UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf
RECEIPT_UPLOAD_ALLOWED_EXT=.jpg,.jpeg,.png,.webp,.pdf
AI_PROMPT_LOGGING_ENABLED=false
AI_PROMPT_LOGGING_REDACTED_ONLY=true
AI_OBSERVABILITY_ENABLED=true
AI_OBSERVABILITY_TRACE_EVENTS_ENABLED=true
AI_OBSERVABILITY_STORE_REDACTED_PROMPTS=false
AI_OBSERVABILITY_STORE_REDACTED_RESPONSES=false
AI_OBSERVABILITY_MAX_PROMPT_SNAPSHOT_CHARS=12000
AI_OBSERVABILITY_RETENTION_DAYS=30
AI_OBSERVABILITY_FAIL_OPEN=true
AI_OBSERVABILITY_DEBUG_LOCAL_ONLY=true
AI_OBSERVABILITY_REDACTION_ENABLED=true
OFFLINE_CACHE_MAX_AGE_DAYS=30

AUTH_SERVICE_PORT=28082
USER_SERVICE_PORT=28083
TRIP_SERVICE_PORT=28080
NOTIFICATION_SERVICE_PORT=28086
EXTERNAL_INTEGRATIONS_SERVICE_PORT=28084
WORKER_SERVICE_PORT=28090
AI_PLANNING_SERVICE_PORT=28000
WEB_APP_PORT=23000
WEB_APP_BIND=127.0.0.1

NEXT_PUBLIC_AUTH_SERVICE_URL=http://127.0.0.1:28082
NEXT_PUBLIC_USER_SERVICE_URL=http://127.0.0.1:28083
NEXT_PUBLIC_TRIP_SERVICE_URL=http://127.0.0.1:28080
NEXT_PUBLIC_NOTIFICATION_SERVICE_URL=http://127.0.0.1:28086
NEXT_PUBLIC_EXTERNAL_INTEGRATIONS_SERVICE_URL=http://127.0.0.1:28084
NEXT_PUBLIC_WORKER_SERVICE_URL=http://127.0.0.1:28090

# Runtime service URLs and safe worker defaults.
AUTH_SERVICE_URL=http://auth-service:8082
AUTH_SERVICE_INTERNAL_URL=http://auth-service:8082
USER_SERVICE_URL=http://user-service:8083
USER_SERVICE_INTERNAL_URL=http://user-service:8083
TRIP_SERVICE_INTERNAL_URL=http://trip-service:8080
NOTIFICATION_SERVICE_URL=http://notification-service:8086
NOTIFICATION_SERVICE_INTERNAL_URL=http://notification-service:8086
EXTERNAL_INTEGRATIONS_SERVICE_URL=http://external-integrations-service:8084
EXTERNAL_INTEGRATIONS_SERVICE_INTERNAL_URL=http://external-integrations-service:8084
WORKER_SERVICE_INTERNAL_URL=http://worker-service:8090
AI_PLANNING_SERVICE_URL=http://ai-planning-service:8000
AUTH_POSTGRES_DB=auth_service
USER_POSTGRES_DB=user_service
NOTIFICATION_POSTGRES_DB=notification_service
EXTERNAL_INTEGRATIONS_POSTGRES_DB=external_integrations_service
AUTH_DATABASE_URL=postgres://travelai:change_me_to_secure_database_value_32_bytes_min@postgres:5432/auth_service?sslmode=disable
USER_DATABASE_URL=postgres://travelai:change_me_to_secure_database_value_32_bytes_min@postgres:5432/user_service?sslmode=disable
NOTIFICATION_DATABASE_URL=postgres://travelai:change_me_to_secure_database_value_32_bytes_min@postgres:5432/notification_service?sslmode=disable
GENERATION_JOBS_ENABLED=true
GENERATION_JOB_DISPATCH_MODE=queue
GENERATION_JOB_WORKER_ENABLED=true
WORKER_ENABLED=true
WORKER_CONCURRENCY=1
WORKER_SHUTDOWN_TIMEOUT_SECONDS=45
DATA_EXPORT_ENABLED=true
RECEIPT_STORAGE_PROVIDER=local
RECEIPT_STORAGE_LOCAL_DIR=/var/app/receipts
TRIP_DATA_EXPORT_STORAGE_DIR=/var/app/exports
USER_DATA_EXPORT_STORAGE_DIR=/var/app/exports
DATA_EXPORT_TTL_HOURS=24
DATA_EXPORT_MAX_TRIP_EXPORT_MB=100
DATA_EXPORT_INCLUDE_RECEIPT_FILES_DEFAULT=false
DATA_EXPORT_CLEANUP_ENABLED=true
DATA_EXPORT_CLEANUP_INTERVAL_MINUTES=60
ACCOUNT_EXPORT_TRIP_DATA_ENABLED=true
TRIP_EXPORT_TIMEOUT_SECONDS=60
